{
  "name": "nouvelle-app",
  "private": true,
  "version": "0.1.0",
  "main": "apps/mobile/index.ts",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "corepack pnpm --filter @nouvelle-app/web dev",
    "dev:api": "corepack pnpm --filter @nouvelle-app/api dev",
    "dev:mobile": "corepack pnpm --filter @nouvelle-app/mobile start",
    "android:mobile": "corepack pnpm --filter @nouvelle-app/mobile android",
    "build:watch:fenix": "corepack pnpm --filter @nouvelle-app/fenix-connect-iq build",
    "build:watch:edge": "corepack pnpm --filter @nouvelle-app/edge-connect-iq build",
    "diag:garmin-hci": "python scripts/parse_garmin_btsnoop.py",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "echo \"Add your migration runner here\""
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
