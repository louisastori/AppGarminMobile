{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nouvelle-app/domain/*": ["packages/domain/src/*"],
      "@nouvelle-app/connectors/*": ["packages/connectors/src/*"],
      "@nouvelle-app/shared/*": ["packages/shared/src/*"],
      "@nouvelle-app/ui/*": ["packages/ui/src/*"]
    }
  }
}
